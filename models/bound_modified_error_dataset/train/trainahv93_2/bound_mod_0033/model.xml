<?xml version='1.0' encoding='utf-8'?>
<nta>
    <declaration>const int N = 2;

const int a=2;
const int b=5;
const int c=1;
const int d=2;
const int e=1;

typedef int[1, N] id_t;
int cnt;

chan exit_chan;
chan lower;
chan raise;
chan approach;</declaration>
    <template>
        <name>train</name>
        <parameter>const id_t id</parameter>
        <declaration>clock x;</declaration>
        <location id="train_0">
            <name>train0</name>
        </location>
        <location id="train_1">
            <name>train1</name>
            <label kind="invariant">x &lt;= b</label>
        </location>
        <location id="train_2">
            <name>train2</name>
            <label kind="invariant">x &lt;= b</label>
        </location>
        <location id="train_3">
            <name>train3</name>
            <label kind="invariant">x &lt;= b</label>
        </location>
        <init ref="train_0" />
        <transition>
            <source ref="train_2" />
            <target ref="train_3" />
        </transition>
        <transition>
            <source ref="train_3" />
            <target ref="train_0" />
            <label kind="guard">x &lt;= b</label>
            <label kind="synchronisation">exit_chan?</label>
        </transition>
        <transition>
            <source ref="train_1" />
            <target ref="train_2" />
            <label kind="guard">x &gt; a</label>
        </transition>
        <transition>
            <source ref="train_0" />
            <target ref="train_1" />
            <label kind="synchronisation">approach?</label>
            <label kind="assignment">x = 0</label>
        </transition>
    </template>
    <template>
        <name>gate</name>
        <declaration>clock y;</declaration>
        <location id="gate_0">
            <name>gate0</name>
        </location>
        <location id="gate_1">
            <name>gate1</name>
            <label kind="invariant">y &lt;= c</label>
        </location>
        <location id="gate_2">
            <name>gate2</name>
        </location>
        <location id="gate_3">
            <name>gate3</name>
            <label kind="invariant">y &lt;= d</label>
        </location>
        <init ref="gate_0" />
        <transition>
            <source ref="gate_1" />
            <target ref="gate_2" />
            <label kind="guard">y &lt;= c</label>
        </transition>
        <transition>
            <source ref="gate_2" />
            <target ref="gate_3" />
            <label kind="synchronisation">raise?</label>
            <label kind="assignment">y = 0</label>
        </transition>
        <transition>
            <source ref="gate_0" />
            <target ref="gate_1" />
            <label kind="synchronisation">lower?</label>
            <label kind="assignment">y = 0</label>
        </transition>
        <transition>
            <source ref="gate_3" />
            <target ref="gate_0" />
            <label kind="guard">y &gt;= c &amp;&amp; y &lt;= d</label>
        </transition>
    </template>
    <template>
        <name>controller</name>
        <declaration>clock z;</declaration>
        <location id="controller_0">
            <name>controller0</name>
        </location>
        <location id="controller_1">
            <name>controller1</name>
            <label kind="invariant">z &lt;= 6</label>
        </location>
        <location id="controller_2">
            <name>controller2</name>
        </location>
        <location id="controller_3">
            <name>controller3</name>
            <label kind="invariant">z &lt;= e</label>
        </location>
        <init ref="controller_0" />
        <transition>
            <source ref="controller_0" />
            <target ref="controller_1" />
            <label kind="synchronisation">approach!</label>
            <label kind="assignment">z = 0, cnt = 1</label>
        </transition>
        <transition>
            <source ref="controller_1" />
            <target ref="controller_1" />
            <label kind="synchronisation">approach!</label>
            <label kind="assignment">cnt = cnt + 1</label>
        </transition>
        <transition>
            <source ref="controller_1" />
            <target ref="controller_1" />
            <label kind="synchronisation">exit_chan!</label>
            <label kind="assignment">cnt = cnt - 1</label>
        </transition>
        <transition>
            <source ref="controller_2" />
            <target ref="controller_2" />
            <label kind="synchronisation">approach!</label>
            <label kind="assignment">cnt = cnt + 1</label>
        </transition>
        <transition>
            <source ref="controller_2" />
            <target ref="controller_2" />
            <label kind="guard">cnt &gt; 1</label>
            <label kind="synchronisation">exit_chan!</label>
            <label kind="assignment">cnt = cnt - 1</label>
        </transition>
        <transition>
            <source ref="controller_2" />
            <target ref="controller_3" />
            <label kind="guard">cnt == 1</label>
            <label kind="synchronisation">exit_chan!</label>
            <label kind="assignment">z = 0, cnt = 0</label>
        </transition>
        <transition>
            <source ref="controller_3" />
            <target ref="controller_0" />
            <label kind="guard">z &lt;= e</label>
            <label kind="synchronisation">raise!</label>
        </transition>
        <transition>
            <source ref="controller_3" />
            <target ref="controller_2" />
            <label kind="guard">z &lt;= e</label>
            <label kind="synchronisation">approach!</label>
            <label kind="assignment">cnt = cnt + 1</label>
        </transition>
        <transition>
            <source ref="controller_1" />
            <target ref="controller_2" />
            <label kind="guard">z == e</label>
            <label kind="synchronisation">lower!</label>
        </transition>
    </template>
    <system>system train, gate, controller;</system>
</nta>